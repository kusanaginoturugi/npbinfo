{
  "name": "npbinfo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"wrangler dev\"",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "deploy:og": "wrangler deploy --config og-worker/wrangler.jsonc",
    "dev:og": "wrangler dev --config og-worker/wrangler.jsonc --test-scheduled"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/vite-plugin": "^1.32.3",
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4",
    "vite-plugin-pwa": "^1.3.0",
    "wrangler": "^4.83.0"
  }
}
