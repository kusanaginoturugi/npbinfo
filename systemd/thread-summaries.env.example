# ~/.config/npbinfo/thread-summaries.env に置く（このファイルはコミットしない）
# スレ要約はローカル llama.cpp（translategemma-12b）が既定なので、必要なのは
# Worker への push 用トークンだけ。ai-comments.env と共有しないこと
#（あちらの LLM_MODEL=Gemini がこちらの既定を上書きして事故るため）。
REFRESH_TOKEN=your-refresh-token
# 任意の上書き（既定値は scripts/generate-thread-summaries.sh を参照）
#LLM_BASE_URL=http://localhost:8080/v1
#LLM_MODEL=translategemma-12b
#THREADS_LIMIT=30
#RES_PER_THREAD=30
#FETCH_SLEEP=3
