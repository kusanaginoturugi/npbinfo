# ~/.config/npbinfo/ai-comments.env に置く（このファイルはコミットしない）
LLM_API_KEY=your-gemini-api-key
REFRESH_TOKEN=your-refresh-token
# 任意の上書き（既定値は scripts/generate-ai-comments.sh を参照）
#LLM_MODEL=models/gemini-3.5-flash
#LLM_BASE_URL=http://localhost:8080/v1
#LLM_SLEEP=5
#LLM_TEMPERATURE=1.3
# 生成対象の絞り込み（team=チーム調子 / stats=個人成績 / schedule=今日の見所 / stadium=球場案内）
# 既定は日次対象。stadium は専用 timer から月・木だけ実行する。
#SUBJECTS=team stats schedule
# キャラ設定は prompts/personas/<slug>.txt で管理する（common.txt と合成される）。
# SYSTEM_PROMPT は合成を無視した全体上書き用（単発の実験向け）
#SYSTEM_PROMPT=...
